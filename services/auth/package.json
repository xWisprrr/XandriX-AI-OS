{
  "name": "@xandrix/auth",
  "version": "0.0.1",
  "private": true,
  "description": "XandriX AI OS — Authentication and authorization service",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
